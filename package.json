{
    "name": "@codemonster-ru/vueiconify",
    "version": "1.2.0",
    "description": "Open source vue icon library.",
    "keywords": [
        "vue",
        "vue3",
        "icons",
        "icon-library",
        "svg-icons",
        "design-system"
    ],
    "homepage": "https://vueiconify.com/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/codemonster-ru/vueiconify.git"
    },
    "bugs": {
        "url": "https://github.com/codemonster-ru/vueiconify/issues"
    },
    "author": "Kirill Kolesnikov",
    "license": "MIT",
    "main": "./dist/index.ts.umd.js",
    "module": "./dist/index.ts.mjs",
    "types": "./dist/lib/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/lib/index.d.ts",
                "default": "./dist/index.ts.mjs"
            },
            "require": {
                "types": "./dist/lib/index.d.ts",
                "default": "./dist/index.ts.umd.js"
            }
        }
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "dev": "vite dev --force --mode development",
        "create-icon": "node ./scripts/create-icon.mjs",
        "generate": "node ./scripts/generate-icons.mjs",
        "validate-icons": "node ./scripts/generate-icons.mjs --validate-only",
        "changeset": "changeset",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint . --ext .ts,.vue,.mts",
        "build": "npm run generate && vite build --mode production",
        "build:showcase": "vite build --config vite.showcase.config.mts",
        "typecheck": "vue-tsc --noEmit",
        "render": "node ./test/render-consumer.mjs",
        "smoke": "npm run build && tsc -p tsconfig.smoke.json",
        "version-packages": "changeset version",
        "release": "npm run build && npm run render && npm audit signatures && changeset publish"
    },
    "peerDependencies": {
        "vue": "^3.5.0"
    },
    "devDependencies": {
        "@changesets/changelog-github": "^0.5.2",
        "@changesets/cli": "^2.29.7",
        "@types/node": "^20.14.10",
        "@typescript-eslint/eslint-plugin": "^7.16.0",
        "@vitejs/plugin-vue": "^5.0.5",
        "@vue/eslint-config-typescript": "^13.0.0",
        "@vue/server-renderer": "^3.5.12",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.3",
        "eslint-plugin-vue": "^9.27.0",
        "prettier": "^3.3.2",
        "sass": "^1.77.8",
        "typescript": "^5.5.3",
        "vite": "^6.0.11",
        "vite-plugin-dts": "^4.5.0",
        "vite-plugin-lib-inject-css": "^2.1.1",
        "vue": "^3.5.12",
        "vue-tsc": "^2.0.21"
    }
}
